# ============================================================
# .gitignore — Text-enhanced Graph Representation Learning
# ============================================================

# --- Data ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/README.md

# --- Model checkpoints ---
checkpoints/
*.pt
*.pth
*.ckpt

# --- Experiment outputs ---
outputs/
runs/
wandb/
*.log

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ---
venv/
env/
ENV/
.venv/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- TensorBoard ---
events.out.tfevents.*

# --- Misc ---
.env
